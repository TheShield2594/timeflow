# Dataverse organisation URL (required for production / PA host builds).
# Find it in the Power Platform admin centre under Environments → your environment → URL.
# Example: https://myorg.crm.dynamics.com
#
# In development (Vite dev server outside PA host), the app uses a
# localStorage-backed mock and this variable is not needed.
VITE_DATAVERSE_ORG_URL=https://yourorg.crm.dynamics.com
